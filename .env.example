# Copy to .env.local and fill in. Never commit real values.

# Anthropic — used by AnthropicAIClient (server only). Not needed in test mode.
ANTHROPIC_API_KEY=

# Supabase — used by lib/db. Not needed for the test harness.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to 1 to force the deterministic test harness (Mock AI, text voice,
# fixed clock, seeded RNG, seeded Returner profile). Playwright sets this.
HABLA_TEST_MODE=
